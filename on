<script>
  // Pemicu Tombol Keyboard Terintegrasi
  document.addEventListener('keydown', (e) => {
    const financeBox = document.querySelector('.finance-container');
    const announceBox3 = document.querySelector('.announcement-container');
    const announceBox5 = document.querySelector('.announcement-container-5');
    const sedekahBox = document.getElementById('sedekahMarquee');

    if (e.key === '1') toggleFullscreen();

    if (e.key === '2' && financeBox) {
        financeBox.classList.toggle('active');
        if(announceBox3) announceBox3.classList.remove('active');
        if(announceBox5) announceBox5.classList.remove('active');
        if(sedekahBox) sedekahBox.classList.remove('active');
    }

    if (e.key === '3' && announceBox3) {
        announceBox3.classList.toggle('active');
        if (announceBox5) announceBox5.classList.remove('active');
        if (financeBox) financeBox.classList.remove('active');
        if (sedekahBox) sedekahBox.classList.remove('active');
    }
            
    if (e.key === '5' && announceBox5) {
        announceBox5.classList.toggle('active');
        if (announceBox3) announceBox3.classList.remove('active');
        if (financeBox) financeBox.classList.remove('active');
        if (sedekahBox) sedekahBox.classList.remove('active');
    }

    if (e.key === '6' && sedekahBox) {
        sedekahBox.classList.toggle('active');
        if (announceBox3) announceBox3.classList.remove('active');
        if (announceBox5) announceBox5.classList.remove('active');
        if (financeBox) financeBox.classList.remove('active');
    }

    if (e.key === '7') {
      const theme = document.getElementById("theme-link");
      if (theme) {
        theme.setAttribute("href", theme.getAttribute("href") === "style.css" ? "style-K.css" : "style.css");
      }
    }

    if (e.key === '9') {
      const modal = document.getElementById("configModal");
      if (modal.style.display === "none" || modal.style.display === "") {
        document.getElementById("inputMarquee").value = document.querySelector(".marquee span").innerText;
        modal.style.display = "flex";
      } else {
        tutupConfig();
      }
    }

    if (e.key === '0') {
      if (confirm("Apakah Anda yakin ingin mereset tampilan ke pengaturan awal?")) {
        localStorage.removeItem("marqueeTeks");
        location.reload();
      }
    }

    if (e.key === 'Enter' || e.keyCode === 13) toggleFullscreen();
  }); 

  function toggleFullscreen() {
    if (!document.fullscreenElement) {
      document.documentElement.requestFullscreen().catch((err) => {
        console.error(`Gagal masuk mode fullscreen: ${err.message}`);
      });
    } else {
      document.exitFullscreen();
    }
  }

  document.addEventListener('click', (e) => {
    if(document.getElementById("configModal").style.display === "flex" && e.target.closest("#configModal > div")) return;
    toggleFullscreen();
  });

  function tutupConfig() { document.getElementById("configModal").style.display = "none"; }

  function simpanConfig() {
    const marqueeBaru = document.getElementById("inputMarquee").value;
    if(marqueeBaru) document.querySelector(".marquee span").innerText = marqueeBaru;
    localStorage.setItem("marqueeTeks", marqueeBaru);
    tutupConfig();
    alert("Pengaturan berhasil disimpan!");
  }

  window.addEventListener('load', () => {
    const sMarquee = localStorage.getItem("marqueeTeks");
    if(sMarquee) document.querySelector(".marquee span").innerText = sMarquee;
    loadJadwalSholat(); // Panggil fetch API saat load
  });
</script>

<script>
// Real-time jam digital & Hijriah
setInterval(() => {
  const n = new Date();
  document.getElementById("hDisplay").textContent = String(n.getHours()).padStart(2, '0');
  document.getElementById("mDisplay").textContent = String(n.getMinutes()).padStart(2, '0');

  const hari = ["Minggu","Senin","Selasa","Rabu","Kamis","Jumat","Sabtu"];
  const bulan = ["Januari","Februari","Maret","April","Mei","Juni","Juli","Agustus","September","Oktober","November","Desember"];

  const tanggalDisplay = document.getElementById("tanggalDisplay");
  if(tanggalDisplay) {
     tanggalDisplay.textContent = `${hari[n.getDay()]}, ${n.getDate()} ${bulan[n.getMonth()]} ${n.getFullYear()}`;
  }

  const hijriMonths = ["Muharram","Safar","Rabiul Awal","Rabiul Akhir","Jumadil Awal","Jumadil Akhir","Rajab","Sya'ban","Ramadhan","Syawal","Dzulqaidah","Dzulhijjah"];
  const fmt = new Intl.DateTimeFormat('id-ID-u-ca-islamic-umalqura', { day:'numeric', month:'numeric', year:'numeric' });

  try {
    const parts = fmt.formatToParts(n);
    const day = parts.find(p=>p.type==='day').value;
    const month = parts.find(p=>p.type==='month').value;
    const year = parts.find(p=>p.type==='year').value;

    const hijriDisplay = document.getElementById("hijriDisplay");
    if(hijriDisplay) {
       hijriDisplay.innerHTML = `${day} ${hijriMonths[month-1]} ${year} H`;
    }
  } catch(e) {}
}, 1000);  
</script>

<script>
// FUNGSI LOAD JADWAL DARI API MYQURAN
async function loadJadwalSholat() {
  const lokasiId = "1108";
  const tanggalIso = new Date().toISOString().slice(0, 10).replace(/-/g, '/'); // Format YYYY/MM/DD
  
  try {
    const response = await fetch(`https://api.myquran.com/v2/sholat/jadwal/${lokasiId}/${tanggalIso}`);
    const data = await response.json();
    
    if(data.status && data.data && data.data.jadwal) {
      const j = data.data.jadwal;
      
      document.getElementById("imsak").textContent   = j.imsak;
      document.getElementById("subuh").textContent   = j.subuh;
      document.getElementById("dzuhur").textContent  = j.dzuhur;
      document.getElementById("ashar").textContent   = j.ashar;
      document.getElementById("maghrib").textContent = j.maghrib;
      document.getElementById("isya").textContent    = j.isya;

      window.jadwal = {
        subuh: j.subuh,
        dzuhur: j.dzuhur,
        ashar: j.ashar,
        maghrib: j.maghrib,
        isya: j.isya
      };
    }
  } catch (error) {
    console.error("Gagal mengambil data jadwal sholat:", error);
  }
}

// Muat ulang jadwal setiap pergantian hari jam 00:01
setInterval(() => {
  const now = new Date();
  if(now.getHours() === 0 && now.getMinutes() === 1) {
    loadJadwalSholat();
  }
}, 60000);
</script>

<script>
let modeIqomahActive = false;
let sedangProses = false;
let statusAdzan = {};

function updateCountdown(){
  if(!window.jadwal) return;

  const now = new Date(new Date().getTime() + 28000);
  const today = new Date();
  const hariIni = today.getDay();

  const list = [
    { n:"Subuh",   t: jadwal.subuh },
    { n:"Dzuhur",  t: jadwal.dzuhur },
    { n:"Ashar",   t: jadwal.ashar },
    { n:"Maghrib", t: jadwal.maghrib },
    { n:"Isya",    t: jadwal.isya }
  ];

  let next = null;
  list.forEach(j => {
    const [h,m] = j.t.split(":");
    const d = new Date(today.getFullYear(), today.getMonth(), today.getDate(), h, m, 0);
    if(d > now && !next){
      next = {...j, d};
    }
  });

  if(!next){
    const [h,m] = jadwal.subuh.split(":");
    const besokSubuh = new Date(today.getFullYear(), today.getMonth(), today.getDate() + 1, h, m, 0);
    next = { n: "Subuh", d: besokSubuh };
  }

  const diff = next.d - now;
  const totalDetik = Math.floor(diff / 1000);											 
  const h = String(Math.floor(diff / 3600000)).padStart(2,"0");
  const m = String(Math.floor((diff % 3600000) / 60000)).padStart(2,"0");
  const s = String(Math.floor((diff % 60000) / 1000)).padStart(2,"0");

  const countdownElement = document.getElementById("countdown");
  if(countdownElement) countdownElement.textContent = `${next.n.toUpperCase()} :  ${h}: ${m}: ${s}`;

  const overlay = document.getElementById("universalOverlay");
  const overlayCD = document.getElementById("overlayCountdown");
  const overlayStatus = document.getElementById("overlayStatus");
  const jumatOverlay = document.getElementById("jumatOverlay");
  const jumatCD = document.getElementById("jumatCountdown");
  const beep = document.getElementById("beepAudio");

  overlay.style.display = "none";
  jumatOverlay.style.display = "none";

  if(totalDetik <= 300 && totalDetik > 0){
    if(hariIni === 5 && next.n === "Dzuhur"){
      jumatOverlay.style.display = "flex";
      jumatCD.textContent = `${m}:${s}`;
    } else {
      overlay.style.display = "flex";
      overlayStatus.textContent = "MENUJU ADZAN";
      overlayCD.textContent = `${m}:${s}`;
      overlayCD.style.color = "white"; 
    }
  }
  else if(totalDetik === 0){
    if(beep) beep.play();
    if(hariIni === 5 && next.n === "Dzuhur"){
      modeIqomahActive = false;
      jumatOverlay.style.display = "flex";
    } else {
      setTimeout(()=>{
        modeIqomahActive = true;
        window.iqomahEnd = new Date().getTime() + 480000; 
      }, 5000);
    }
  }
  else if(modeIqomahActive){
    const sisa = window.iqomahEnd - new Date().getTime();
    if(sisa > 0){
      overlay.style.display = "flex";
      overlayStatus.textContent = "MENUJU IQOMAH";
      overlayStatus.style.color = "white";
      overlayStatus.style.fontSize = "4rem";       
      overlayStatus.style.letterSpacing = "5px";   
      const im = String(Math.floor(sisa/60000)).padStart(2,"0");
      const is = String(Math.floor((sisa%60000)/1000)).padStart(2,"0");
      overlayCD.textContent = `${im}:${is}`;
    } else {
      overlay.style.display = "none";
      modeIqomahActive = false;
    }
  }
}
setInterval(updateCountdown, 1000);
</script>

<script>
const hariBesar = [
  {n:"Isra Mi'raj Nabi (ﷺ)",m:1,d:16},
  {n:"Awal Ramadhan",m:2,d:19},
  {n:"Nuzulul Qur'an",m:3,d:7},
  {n:"Idul Fitri",m:3,d:20},
  {n:"Idul Adha",m:5,d:27},
  {n:"Tahun Baru Islam",m:6,d:16},
  {n:"Maulid Nabi (ﷺ)",m:8,d:25}
];

function updateHariBesar(){
  const now = new Date();
  let dekat = null, sel = 9999;
  hariBesar.forEach(h => {
    let t = new Date(now.getFullYear(), h.m-1, h.d);
    if (t < now) t.setFullYear(t.getFullYear()+1);
    let s = Math.ceil((t-now)/86400000);
    if (s < sel){ sel = s; dekat = h; }
  });
  const hbText = document.getElementById("hariBesarText");
  if(hbText && dekat) hbText.textContent = `${dekat.n} — ${sel} hari lagi`;
}
updateHariBesar();
</script>

