<script>
// Deteksi Auto Audio Adzan
setInterval(() => {
  if (!window.jadwal || sedangProses) return;
  const now = new Date(new Date().getTime() + 28000);
  const jamSekarang = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
  ["subuh","dzuhur","ashar","maghrib","isya"].forEach(w => {
    if (window.jadwal[w] === jamSekarang && !statusAdzan[w]) {
      sedangProses = true;
      statusAdzan[w] = true;
      const audio = document.getElementById("adzanAudio");
      if(audio) audio.play().catch(e => {});
      setTimeout(() => { sedangProses = false; }, 65000); // Reset gap proses setelah 1 menit lewat
    }
  });
}, 1000);

setInterval(() => {
  const n = new Date();
  if(n.getHours() === 0 && n.getMinutes() === 0) statusAdzan = {};
}, 60000);
</script>

